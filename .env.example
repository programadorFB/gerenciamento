# === Banco de Dados (usa o postgres_principal existente na VPS) ===
POSTGRES_PASSWORD=1234

# === Seguranca ===
SECRET_KEY=troque-para-uma-chave-segura
JWT_SECRET_KEY=troque-para-uma-chave-segura

# === CORS (dominios que acessam a API) ===
CORS_ORIGINS=https://gerenciamento.sortehub.online,https://gerenciamento-1.onrender.com,http://localhost:5173

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=seu-token-aqui

# === Rede Docker externa (onde postgres_principal e redis estao) ===
# Descubra com: docker network ls | grep -i back
INFRA_NETWORK=backend_default
